# Add this to your existing .env.local file

# Transcript Parser Service URL
TRANSCRIPT_PARSER_URL=http://localhost:8787
# In production: TRANSCRIPT_PARSER_URL=https://your-worker.railway.app

# Standalone landing app origin (used for marketing-route redirects)
NEXT_PUBLIC_LANDING_ORIGIN=https://stuplanning.com

# Required for cross-device / cookie-reset anonymous-to-auth linking.
# Use a long random value (32+ bytes) and keep it stable across deployments.
IDENTITY_LINK_HMAC_SECRET=replace-with-a-long-random-secret

# Enable durable Mastra automatic generation workflow for /grad-plan/createV2.
# Values accepted: true/false (or 1/0, yes/no, on/off)
GRAD_PLAN_AUTOMATIC_MASTRA_WORKFLOW=false

# Show or hide Quick Course Search widget in course selection UI.
# Keep false for now until search UX/data issues are resolved.
NEXT_PUBLIC_GRAD_PLAN_QUICK_COURSE_SEARCH_ENABLED=false

# Enable internal beta route /grad-plan/createV3.
GRAD_PLAN_V3_ENABLED=false
NEXT_PUBLIC_GRAD_PLAN_V3_ENABLED=false

# Enable createV3 devtools rail with trace timeline replay.
GRAD_PLAN_V3_DEVTOOLS_ENABLED=false
NEXT_PUBLIC_GRAD_PLAN_V3_DEVTOOLS_ENABLED=false

# Enable live durable v3 generation jobs runtime.
GRAD_PLAN_V3_LIVE_JOBS_ENABLED=false

# Enable mini chat command/reply panel for createV3.
NEXT_PUBLIC_GRAD_PLAN_V3_MINI_CHAT_ENABLED=false

# Optional secret for internal generation worker endpoint.
# If omitted, worker endpoint allows local non-production calls without auth.
GRAD_PLAN_GENERATION_WORKER_SECRET=replace-with-random-secret

# Grad planner agent cross-app handoff configuration.
GRAD_PLANNER_AGENT_URL=https://degree-auditing.stuplanning.com
GRAD_PLANNER_HANDOFF_SECRET=replace-with-random-hmac-secret
GRAD_PLANNER_HANDOFF_AUDIENCE=grad-planner-agent
GRAD_PLANNER_HANDOFF_TTL_SECONDS=60
